APP_NAME=notus-label-agent
APP_VERSION=0.1.0
DEBUG=false

# Database
POSTGRES_USER=notus
POSTGRES_PASSWORD=changeme
POSTGRES_DB=notus
DATABASE_URL=postgresql+asyncpg://notus:changeme@postgres:5432/notus
DATABASE_URL_SYNC=postgresql://notus:changeme@postgres:5432/notus

# Redis
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=300

# OCR
TESSERACT_CMD=/usr/bin/tesseract
PADDLE_USE_GPU=false

# Storage
UPLOADS_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# Logging
LOG_LEVEL=INFO
